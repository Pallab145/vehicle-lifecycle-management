# ─── Server Configuration ───
NODE_ENV="development"
PORT=5000
SERVICE_NAME="vehicle-lifecycle-backend"
LOG_LEVEL="info"

# ─── Database Configuration ───
DATABASE_URL=""
DIRECT_URL=""
DATABASE_POOL_MAX=10

# ─── Security & CORS ───
APP_DOMAIN="localhost"
ALLOWED_ORIGINS="http://localhost:3000"
TRUST_PROXY=1

# ─── Authentication & JWT ───
JWT_SECRET=""
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ─── Redis (BullMQ / Caching) ───
REDIS_URL="redis://localhost:6379"

# ─── Email Service (Resend) ───
EMAIL_FROM="onboarding@resend.dev"
RESEND_API_KEY=""

# ─── Blockchain Configuration ───
RPC_URL="https://rpc.ahaarx.com"
WS_RPC_URL="wss://rpc.ahaarx.com/ws"
CHAIN_ID=4100
# ─── Enterprise Relayer Master Keys ───
MASTER_ADMIN_KEY=""
RTO_MASTER_KEY=""
MANUFACTURER_MASTER_KEY=""
POLICE_MASTER_KEY=""
INSURANCE_MASTER_KEY=""
PUC_MASTER_KEY=""
SCRAP_MASTER_KEY=""
BANK_MASTER_KEY=""

MORTH_GNOSIS_SAFE_ADDRESS=""
MORTH_ADMIN_1_WALLET=""
MORTH_ADMIN_2_WALLET=""
MORTH_ADMIN_3_WALLET=""
MORTH_ADMIN_1_EMAIL=""
MORTH_ADMIN_2_EMAIL=""
MORTH_ADMIN_3_EMAIL=""

GOV_ADMIN_PRIVATE_KEY=""
GOV_ADMIN_WALLET_ADDRESS=""

CONTRACT_DVP_ADDRESS=""
CONTRACT_OWNERSHIP_ADDRESS=""
CONTRACT_CHALLAN_ADDRESS=""
CONTRACT_INSURANCE_ADDRESS=""
CONTRACT_PUC_ADDRESS=""
CONTRACT_LOAN_ADDRESS=""

